{
    "Jans": {
        "commonTypes": {
            "WorkspaceContext": {
                "type": "Record",
                "attributes": {
                    "cwd":             { "required": false, "type": "String" },
                    "permission_mode": { "required": false, "type": "String" },
                    "transcript_path": { "required": false, "type": "String" }
                }
            },
            "SignatureContext": {
                "type": "Record",
                "attributes": {
                    "matches":    { "required": false, "type": "Long" },
                    "categories": {
                        "required": false,
                        "type": "Set",
                        "element": { "type": "String" }
                    },
                    "severity":   { "required": false, "type": "Long" }
                }
            },
            "PolicyContext": {
                "type": "Record",
                "attributes": {
                    "compliant":  { "required": false, "type": "Boolean" },
                    "violations": {
                        "required": false,
                        "type": "Set",
                        "element": { "type": "String" }
                    }
                }
            },
            "TrajectoryContext": {
                "type": "Record",
                "attributes": {
                    "label":      { "required": false, "type": "Entity", "name": "Jans::Label" },
                    "step_count": { "required": false, "type": "Long" },
                    "taints": {
                        "required": false,
                        "type": "Set",
                        "element": { "type": "Entity", "name": "Jans::Taint" }
                    }
                }
            }
        },
        "entityTypes": {
            "Workload": {
                "shape": {
                    "type": "Record",
                    "attributes": {
                        "provider_id": { "required": false, "type": "String" }
                    }
                }
            },
            "User": {},
            "Label": {},
            "Taint": {},
            "Trajectory": {
                "shape": {
                    "type": "Record",
                    "attributes": {
                        "step_count": { "required": true,  "type": "Long" },
                        "label":      { "required": false, "type": "Entity", "name": "Jans::Label" },
                        "taints": {
                            "required": false,
                            "type": "Set",
                            "element": { "type": "Entity", "name": "Jans::Taint" }
                        }
                    }
                }
            },
            "Message": {
                "memberOfTypes": ["Trajectory"],
                "shape": {
                    "type": "Record",
                    "attributes": {
                        "content": { "required": true, "type": "String" },
                        "role":    { "required": true, "type": "String" }
                    }
                }
            },
            "File": {
                "shape": {
                    "type": "Record",
                    "attributes": {
                        "label": { "required": false, "type": "Entity", "name": "Jans::Label" }
                    }
                }
            },
            "Shell": {},
            "API":   {},
            "Tool":  {}
        },
