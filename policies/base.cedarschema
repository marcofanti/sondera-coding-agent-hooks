// Legacy schema for CedarPolicyEngine (old namespace).
// The production engine now uses CedarlingPolicyEngine with schema.json (Jans:: namespace).
// Kept so cedar_policy_loading tests continue to compile and pass during migration.

entity Agent = {
    "provider_id": String,
};

entity Trajectory = {
    "step_count": Long,
    "label": Label,
    "taints": Set<String>,
};

entity Label = {};

entity File = {
    "path": String,
};

entity Tool = {};

entity Message = {
    "content": String,
    "role": String,
};

entity Taint = {};

action Prompt appliesTo {
    principal: Agent,
    resource: Message,
    context: {
        "command"?: String,
        "path"?: String,
        "url"?: String,
        "content"?: String,
        "role"?: String,
    }
};

action ShellCommand appliesTo {
    principal: Agent,
    resource: Trajectory,
    context: {
        "command": String,
        "working_dir": String,
    }
};

action WebFetch appliesTo {
    principal: Agent,
    resource: Trajectory,
    context: {
        "url": String,
        "prompt": String,
    }
};

action FileOperation appliesTo {
    principal: Agent,
    resource: File,
    context: {
        "path": String,
        "operation": String,
    }
};

action ToolCall appliesTo {
    principal: Agent,
    resource: Tool,
    context: {}
};
